{
    "preset": "psr12",
    "rules": {
        "array_syntax": {
            "syntax": "short"
        },
        "ordered_class_elements": {
            "order": [
                "use_trait",
                "constant",
                "property",
                "construct",
                "method"
            ]
        },
        "phpdoc_to_param_type": true,
        "phpdoc_to_return_type": true,
        "phpdoc_trim": true,
        "phpdoc_scalar": true,
        "no_unused_imports": true,
        "single_quote": true,
        "space_after_semicolon": true
    }
}