# E2E test database credentials
#
# Copy this file to .env and fill in your values:
#   cp tests/E2E/.env.example tests/E2E/.env
#
# .env is gitignored — never commit real credentials.

E2E_DB_HOST=localhost
E2E_DB_USER=pxmboard
E2E_DB_PASS=
E2E_DB_NAME=pxmboard_e2e

# On Linux with MariaDB/MySQL listening on a Unix socket, uncomment:
# E2E_DB_SOCKET=/run/mysqld/mysqld.sock
